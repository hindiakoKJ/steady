{
  "expo": {
    "name": "Steady",
    "slug": "steady",
    "scheme": "steady",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#5B5BD6"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ph.hnscorpph.steady",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Steady needs your location to log weather conditions during a seizure and to send your location to family contacts.",
        "NSMotionUsageDescription": "Steady uses motion sensors to detect potential seizure activity while the app is open."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#5B5BD6"
      },
      "package": "ph.hnscorpph.steady",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE",
        "SEND_SMS",
        "POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-sensors",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#5B5BD6",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Steady to use your location to record weather and send your position to family during a seizure."
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io",
          "project": "steady",
          "organization": "hindiakokj1"
        }
      ],
      "expo-secure-store"
    ],
    "newArchEnabled": false,
    "experiments": {
      "typedRoutes": true
    },
    "owner": "hindiakokj1",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "474071af-a82b-4d86-8e8b-b0e2c080db77"
      }
    }
  }
}
